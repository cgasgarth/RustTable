# RustTable-owned files use one portable text representation.  The retained
# darktable reference tree is intentionally outside these path-scoped rules.
/.gitattributes text eol=lf
/*.md text eol=lf
/*.toml text eol=lf
/*.yaml text eol=lf
/*.yml text eol=lf
/*.json text eol=lf
/*.lock text eol=lf
/LICENSE text eol=lf
/crates/rusttable-*/** text eol=lf
/crates/xtask/** text eol=lf
/architecture/** text eol=lf
/quality/** text eol=lf
/scripts/** text eol=lf
/shaders/** text eol=lf
/fixtures/** text eol=lf

